{
  "name": "cc-zhipu-hud",
  "version": "0.1.0",
  "description": "Enhanced statusline for Claude Code with Zhipu AI/GLM balance tracking — displays context usage, token costs, GLM Coding Plan quota, and token balance in real-time",
  "type": "module",
  "bin": {
    "cc-zhipu-hud": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "tsc && node --experimental-strip-types --no-warnings --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "claude-code",
    "claude",
    "statusline",
    "zhipu",
    "glm",
    "bigmodel",
    "cost-tracking",
    "balance"
  ],
  "author": "beiyuii",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/beiyuii/cc-zhipu-hud.git"
  },
  "bugs": {
    "url": "https://github.com/beiyuii/cc-zhipu-hud/issues"
  },
  "homepage": "https://github.com/beiyuii/cc-zhipu-hud#readme",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3"
  }
}
